{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": false,

    "baseUrl": ".",
    "paths": {
      // tsc consumes the package's BUILT declarations (flat .d.ts → resolves
      // react/@mui against THIS app's single copy, avoiding the dual-@types/react
      // clash that deep-checking the aliased source would cause). Runtime uses
      // the src alias in vite.config.ts (fast dev). Run `npm run build -w
      // @vectros-ai/react` after changing the lib's types. (Both go away at the
      // registry-pin release cut.)
      // Pin react/react-dom types to THIS app's single @types copy. The flat lib
      // .d.ts still imports `react` types, which tsc resolves from the repo root
      // — a SECOND @types/react identity. It's latent here (no MUI Autocomplete
      // renderInput, the one pattern that surfaces it as a spurious `ref` TS2322),
      // but it broke admin-app's build. Pin it preventatively so adding an
      // Autocomplete here can't silently break tsc.
      "react": ["./node_modules/@types/react"],
      "react/*": ["./node_modules/@types/react/*"],
      "react-dom": ["./node_modules/@types/react-dom"],
      "react-dom/*": ["./node_modules/@types/react-dom/*"]
    },

    "types": ["vite/client", "vitest/globals", "@testing-library/jest-dom"]
  },
  "include": ["src"]
}
