# ---------------------------------------------------------------------------
# app.vectros.ai — environment configuration template
#
# Copy this file to `.env.local` for local development. NEVER commit a real
# `.env.local`. Production values are injected at build time by the CFN
# stack (see ui/app-vectros-ai/template.yml) and the GitLab CI deploy job
# (ui/app-vectros-ai/pipelines/deploy-pipeline.yml), which export these as
# VITE_* env vars before `npm run build`.
#
# Vite exposes ONLY variables prefixed `VITE_` to the client bundle. Any
# secret pattern (passwords, signing keys, etc.) MUST NOT live here — this
# file is shipped to the browser. Cognito User Pool IDs + Client IDs are
# safe to ship; they are public identifiers.
# ---------------------------------------------------------------------------

# DeveloperUserPool ID (shared with ui/developer-portal + ui/admin-app — one
# Cognito identity per email across all three first-party apps). The region is
# encoded as the prefix (e.g. `us-east-1_ABC123` → us-east-1); Amplify v6
# derives it automatically.
VITE_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX

# DeveloperUserPool App Client ID. The first-party apps share a single client
# because they authenticate via Cognito SRP (direct API, not Hosted UI / OAuth
# redirect) — there is no callback-URL allow-list scoped per subdomain.
VITE_COGNITO_USER_POOL_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX

# Developer API base URL. app.vectros.ai calls `GET <this>/developer/scoped-
# token?context=<id>` to mint a Vectros-API st_* bearer scoped to the selected
# AppContext (the context switcher's token swap). For staging this is the same
# host as the Vectros API; they are split into two vars so a partner fork or a
# future split-domain deployment can point them at different origins.
VITE_DEVELOPER_API_URL=https://api.staging.example.com

# Vectros API base URL. The minted st_* unlocks /v1/* — records, schemas,
# folders, documents, search, inference — all scoped to (tenant, context) by
# the token. See VITE_DEVELOPER_API_URL for why this is a separate variable.
VITE_VECTROS_API_URL=https://api.staging.example.com
